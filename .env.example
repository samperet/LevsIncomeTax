PORT=4173
PUBLIC_APP_URL=http://localhost:4173
ADMIN_PASSWORD=levadmin
ADMIN_EMAIL=levsincometax@gmail.com
# Use an address on a Resend-verified domain (e.g. uploads@levsincometax.com).
# onboarding@resend.dev is sandbox-only and only delivers to the Resend account owner.
EMAIL_FROM="Lev's Income Tax <uploads@yourdomain.com>"

# Optional for local testing: set to console to preview emails without sending.
EMAIL_MODE=

# Option 1: Resend
RESEND_API_KEY=

# Option 2: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Cloudflare R2 document storage (S3-compatible)
# Get these from Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Only set if the bucket has a public custom domain; leave empty to use presigned GETs.
R2_PUBLIC_BASE_URL=
